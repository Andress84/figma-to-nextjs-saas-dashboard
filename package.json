{
  "name": "figma-to-nextjs-saas-dashboard",
  "version": "1.0.0",
  "description": "Portfolio SaaS analytics dashboard implemented from an original Figma UI/UX design with Next.js, React, TypeScript, Tailwind CSS, Recharts, Vitest, and Playwright.",
  "private": true,
  "author": "Andrii Kurus (LaimAnd)",
  "license": "MIT",
  "homepage": "https://andress84.github.io/figma-to-nextjs-saas-dashboard/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Andress84/figma-to-nextjs-saas-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/Andress84/figma-to-nextjs-saas-dashboard/issues"
  },
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "saas-dashboard",
    "figma-to-nextjs",
    "figma-to-code",
    "ui-ux",
    "responsive-design",
    "recharts",
    "playwright",
    "vitest",
    "portfolio"
  ],
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24.11.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "fix": "biome check --write . && eslint . --fix",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "check:full": "pnpm check && pnpm test:e2e"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
